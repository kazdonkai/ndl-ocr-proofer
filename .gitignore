# Environment variables (never commit)
backend/.env

# Application config (local settings — commit app.toml.example, not app.toml)
app.toml

# Runtime logs (start.sh output — root-level only)
/logs/

# Evaluation logs that may contain unpublished research material
# correction_events.jsonl is excluded below because it is tracked in v1.0.0 history
# and continues to contain only test-file references.
# The following three files contain private vault document paths or OCR text and are excluded.
evaluation/logs/span_accepted.jsonl
evaluation/logs/user_actions.jsonl
evaluation/logs/learning_candidates.jsonl

# Runtime temporary dictionary — user-specific corrections, not for public repo
data/dictionaries/temporary/*.csv

# Dictionary version archives — auto-generated by TemporaryDictManager, regenerable
data/dictionaries/archive/

# Evaluation session log — accumulated real OCR session data
evaluation/logs/correction_events.jsonl

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/
*.log

# Node / frontend
node_modules/
frontend/dist/
frontend/.env.local

# Obsidian plugin build artifacts
# main.js is tracked as a distribution artifact (generated by `npm run build`)
obsidian-plugin/node_modules/

# Backups generated by save_markdown()
backups/

# Development scratch scripts
scratch/

# Internal developer snapshots (contain dev-env paths, not for public release)
snapshots/

# PDF OCR design documents — internal memo, excluded until OCR implementation phase
docs/claude_code_pdf_ocr_prompt.md
docs/pdf_ocr_design.md

# Non-public evaluation materials — may contain unpublished research text or internal protocols
evaluation/datasets/test_kozuke_mountain.md
evaluation/datasets/test_mismatch_region.md
evaluation/datasets/test_shinano_nyukai.md
evaluation/docs/EXPERIMENTAL_COMPARISON_PROTOCOL.md
evaluation/docs/EXPERIMENTAL_LOG_SCHEMA.md
evaluation/docs/FALSE_POSITIVE_REVIEW.md

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
