# ==========================================
# NDL古典籍OCR 独立校正支援アプリ 環境設定
# ==========================================
# このファイルをコピーして .env を作成し、各自の環境に合わせて編集してください。
# Copy this file to .env and edit for your environment.

# ---- Paths (required) ----

# Obsidian Vault のルートディレクトリ / Obsidian Vault root directory
VAULT_ROOT=/path/to/your/obsidian/vault

# NDL古典籍OCR エンジンのルートディレクトリ / ndlkotenocr-lite clone directory
OCR_ENGINE_PATH=/path/to/ndlkotenocr-lite

# OCR 一時作業ディレクトリ / Temporary directory for OCR processing
OCR_TEMP_ROOT=/tmp/ocr_temp

# ---- Paths (optional overrides) ----

# アプリデータディレクトリ（辞書・評価ログのデフォルト解決元）
# 省略時: backend/ の親ディレクトリ（= proofreading-app リポジトリルート）を自動使用
#
# ── Vault 内に置いたまま使う場合 ──────────────────────────────────────────────
# 設定不要。backend/../ が自動的に proofreading-app/ を指すため現行と同じ動作になる。
#
# ── Vault 外に移動した場合（開発時） ──────────────────────────────────────────
# APP_DATA_DIR=/Users/you/dev/proofreading-app
#
# ── 将来の配布版（.app バンドル内） ───────────────────────────────────────────
# APP_DATA_DIR=/Applications/Proofreading.app/Contents/Resources/app-data
# APP_DATA_DIR=（省略）

# 研究語彙辞書 CSV ディレクトリ
# (省略時: {APP_DATA_DIR}/data/dictionaries)
# DICT_DIR=/path/to/dictionaries

# 評価ログ出力ディレクトリ
# (省略時: {APP_DATA_DIR}/evaluation/logs)
# EVALUATION_DIR=/path/to/evaluation/logs

# ---- Backend server ----

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ---- Ollama AI checker (Phase 2) ----
# AI は「確認器」。OCR confidence が高い正読を単独で上書きしない。
# verdict が review / uncertain の場合は既存候補の比較補助にとどめる。
# likely_correct の場合は「変更しない根拠」として使う。

OLLAMA_BASE_URL=http://localhost:11434
# default: qwen3.5:9b  (/api/chat + think:false)
OLLAMA_DEFAULT_MODEL=qwen3.5:9b
# fallback: qwen2.5:7b-instruct (qwen3.5:9b 不応答時)
OLLAMA_FALLBACK_MODEL=qwen2.5:7b-instruct
# 比較研究専用 (常用から降格 — bench のみ)
# OLLAMA_RESEARCH_MODEL=llama3-elyza-jp-8b

# ---- PDF OCR import (post-migration feature, not yet implemented) ----
# 設計文書: docs/pdf_ocr_design.md
# 実装条件: outside-Vault 移行安定後。pypdfium2 は未追加。現時点では設定しない。
#
# PDF を読み込んでよいディレクトリ（カンマ区切り）
# Vault 内 PDF のみ許可する場合は VAULT_ROOT だけで十分。
# Dropbox や外部パスを追加する場合はカンマで列挙。
# PDF_ALLOWED_ROOTS=/path/to/vault,/Users/you/Dropbox,/Users/you/Documents
#
# PDF→画像変換の解像度（OCR 品質と処理速度のトレードオフ）
# PDF_RENDER_DPI=300
#
# 変換フォーマット: "jpg" | "png"
# PDF_RENDER_FORMAT=jpg
#
# 一時ページ画像キャッシュの保持時間（時間）
# PDF_CACHE_TTL_HOURS=24
